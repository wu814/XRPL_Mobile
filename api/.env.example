# Server
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# Supabase (new project for the mobile app)
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi... (server-only, bypasses RLS)
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-settings-api

# Seed encryption (used with pgp_sym_encrypt). Generate with `openssl rand -base64 48`.
SEED_ENCRYPTION_KEY=replace-with-random-48-byte-base64

# XRPL
XRPL_NETWORK=wss://s.altnet.rippletest.net:51233
XRPL_FAUCET_URL=https://faucet.altnet.rippletest.net/accounts

# CORS - comma-separated origins allowed to call the API
CORS_ORIGINS=http://localhost:8081,exp://127.0.0.1:8081
